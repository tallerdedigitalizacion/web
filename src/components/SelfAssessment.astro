---
import { assessmentAreas } from "@/data/selfAssessment";
import { siteConfig } from "@/config/site";
import { withBase } from "@/utils/paths";
---

<section id="autoevaluacion" class="section section-accent">
  <div class="section-head">
    <span class="eyebrow">Autoevaluación</span>
    <h2>Autoevalua tu Caos Operativo</h2>
    <p>Responde todas las preguntas y recibirás tu resultado frente a nuestro método. Podrás descargar tu diagnóstico y el método de trabajo completo.</p>
  </div>

  <form class="assessment" data-assessment>
    {assessmentAreas.map((area, areaIndex) => (
      <fieldset class="area-block" data-step={areaIndex} hidden={areaIndex !== 0}>
        <legend class="sr-only">{area.name}</legend>
        <div class="wizard-head" aria-live="polite">
          <div>
            <span class="eyebrow">Área {areaIndex + 1} de {assessmentAreas.length}</span>
            <h3>{area.name}</h3>
          </div>
          <div class="wizard-progress" aria-hidden="true">
            <i data-progress-bar style="width: 0%"></i>
          </div>
        </div>
        {area.questions.map((question, questionIndex) => {
          const name = `area-${areaIndex}-q-${questionIndex}`;
          return (
            <div class="question">
              <p>{question}</p>
              <div class="range-answer">
                <strong data-range-label>Sin seleccionar</strong>
                <input
                  type="range"
                  name={name}
                  min="0"
                  max="4"
                  step="1"
                  value="0"
                  data-area={areaIndex}
                  data-question={questionIndex}
                  data-answered="false"
                  aria-label={question}
                />
              </div>
            </div>
          );
        })}
      </fieldset>
    ))}

    <div class="lead-capture assessment-contact" data-assessment-lead hidden>
      <div class="wizard-head" aria-live="polite">
        <div>
          <span class="eyebrow">Paso final</span>
          <h3>Datos para recibir tu diagnóstico</h3>
        </div>
        <div class="wizard-progress" aria-hidden="true">
          <i data-progress-bar style="width: 0%"></i>
        </div>
      </div>
      <p>Para calcular y enviarte el diagnóstico necesitamos guardar tus respuestas y un email de contacto.</p>
      <div class="form-grid">
        <label>Nombre<input required name="nombre" autocomplete="name" /><small>Obligatorio.</small></label>
        <label>Email<input required type="email" name="email" autocomplete="email" /><small>Obligatorio. Lo usamos para enviarte el diagnóstico.</small></label>
        <label>Empresa<input name="empresa" autocomplete="organization" /><small>Opcional.</small></label>
        <label>Cargo<input name="cargo" autocomplete="organization-title" /><small>Opcional.</small></label>
      </div>
      <label class="check"><input required type="checkbox" name="privacidad" /> <span>Acepto la <a href={withBase("/politica-privacidad")}>política de privacidad</a>.</span></label>
      <label class="honeypot" aria-hidden="true">Web<input tabindex="-1" autocomplete="off" name="website" /></label>
      <input type="hidden" name="started_at" data-started-at />
      <p class="form-help" data-assessment-status aria-live="polite"></p>
    </div>

    <p class="wizard-error" data-wizard-error hidden>Responde las 3 preguntas de este paso para continuar.</p>
    <div class="form-actions">
      <button class="btn btn-secondary" type="button" data-prev-step>Anterior</button>
      <button class="btn btn-primary" type="button" data-next-step>Siguiente área</button>
      <button class="btn btn-primary" type="submit" data-submit-assessment hidden>Calcular mi caos operativo</button>
    </div>
  </form>

  <section class="result-panel" data-result hidden aria-live="polite">
    <div class="result-summary">
      <div>
        <span class="eyebrow">Solicitud recibida</span>
        <h3 data-result-title></h3>
        <p data-result-text></p>
        <p class="muted">Esta autoevaluación no sustituye un diagnóstico completo. Sirve para darte una primera lectura y detectar dónde puede haber caos operativo.</p>
      </div>
    </div>
    <div class="result-actions">
      <a class="btn btn-primary" data-event="click_reservar_llamada" href={siteConfig.bookingUrl} target="_blank" rel="noreferrer">Reservar llamada para revisar mi diagnóstico</a>
      <button class="btn btn-secondary" type="button" data-reset-assessment>Reiniciar diagnóstico</button>
    </div>

    <div class="method-download">
      <div class="method-copy">
        <span class="eyebrow">Marco de trabajo</span>
        <h3>Descarga el método completo</h3>
        <p>Si quieres revisar el método completo con todas las áreas de auditoría, puedes descargar una versión resumida del marco de trabajo.</p>
        <img class="method-scorecard" src={withBase("/scorecard-placeholder.svg")} alt="Vista previa del scorecard del método" loading="lazy" width="560" height="360" />
      </div>
      <form class="compact-form" data-method-form action={siteConfig.formEndpoint} method="post">
        <label>Nombre<input required name="nombre" /><small>Obligatorio.</small></label>
        <label>Email<input required type="email" name="email" /><small>Obligatorio. Lo usamos para enviarte la descarga.</small></label>
        <label>Empresa<input name="empresa" /><small>Opcional.</small></label>
        <label class="check"><input required type="checkbox" name="privacidad" /> <span>Acepto la <a href={withBase("/politica-privacidad")}>política de privacidad</a>.</span></label>
        <label class="honeypot" aria-hidden="true">Web<input tabindex="-1" autocomplete="off" name="website" /></label>
        <input type="hidden" name="started_at" data-started-at />
        <button class="btn btn-primary" type="submit" data-event="descarga_metodo">Descargar método completo</button>
        <p class="form-help" data-method-status aria-live="polite">Te enviaremos el método por email.</p>
      </form>
    </div>
  </section>
</section>

<script define:vars={{ areas: assessmentAreas, formEndpoint: siteConfig.formEndpoint, methodPdfPath: siteConfig.methodPdfPath }}>
  const assessment = document.querySelector("[data-assessment]");
  const result = document.querySelector("[data-result]");
  const state = { areaScores: [], total: 0, percent: 0, level: "" };
  const leadStep = areas.length;
  let currentStep = 0;
  const rangeLabels = [
    "Sin seleccionar",
    "Crítico / reactivo / inexistente",
    "Informal / dependiente de personas",
    "Parcialmente estructurado",
    "Estructurado / visible / gobernado",
  ];

  function getInterpretation(total) {
    if (total <= 27) {
      return {
        level: "Tu operación depende demasiado de esfuerzo humano clave.",
        text: "La lectura de ROI es clara: ahora mismo el coste probablemente no está solo en herramientas o sueldos, sino en tiempo directivo perdido, decisiones reactivas y capacidad de crecimiento bloqueada. Si eres CEO, es probable que estés sosteniendo demasiadas cosas con memoria, criterio personal y urgencias diarias. La prioridad no es añadir más complejidad, sino recuperar control operativo y liberar horas de dirección.",
      };
    }
    if (total <= 54) {
      return {
        level: "Tu empresa funciona, pero todavía paga fricción con tiempo del CEO.",
        text: "La empresa probablemente ya tiene cierta estructura, pero hay áreas que consumen más energía de la que deberían. El ROI está en atacar los puntos donde una mejora pequeña puede devolver foco, reducir interrupciones y hacer que el crecimiento pese menos. No parece un problema de trabajar más, sino de decidir mejor dónde poner orden primero.",
      };
    }
    return {
      level: "Hay base operativa, pero el ROI puede estar en afinar los cuellos débiles.",
      text: "Tu empresa muestra señales de gobernanza. Eso no significa que no haya caos operativo: significa que conviene mirar con precisión qué áreas están limitando delegación, escalabilidad o velocidad de decisión. Para un CEO, el retorno puede estar en recuperar tiempo de calidad, quitar ruido del día a día y acercar la operación al nivel que exige la madurez actual del negocio.",
    };
  }

  function apiBaseUrl() {
    if (!formEndpoint || formEndpoint.includes("INSERTAR")) return "";
    return String(formEndpoint).replace(/\/$/, "");
  }

  async function postLead(path, payload) {
    const baseUrl = apiBaseUrl();
    if (!baseUrl) throw new Error("Endpoint de formularios no configurado.");
    const response = await fetch(`${baseUrl}/lead/${path}`, {
      method: "POST",
      headers: { "content-type": "application/json" },
      body: JSON.stringify(payload),
    });
    const data = await response.json().catch(() => ({}));
    if (!response.ok || data.ok === false) {
      throw new Error(data.error || "No se pudo procesar la solicitud.");
    }
    return data;
  }

  function leadPayloadFromForm(formData) {
    return {
      name: String(formData.get("nombre") || ""),
      email: String(formData.get("email") || ""),
      company: String(formData.get("empresa") || ""),
      role: String(formData.get("cargo") || ""),
      privacyAccepted: formData.get("privacidad") === "on",
      marketingAccepted: false,
      website: String(formData.get("website") || ""),
      startedAt: Number(formData.get("started_at") || Date.now()),
      pageUrl: window.location.href,
      userAgent: navigator.userAgent,
    };
  }

  function collectAnswers() {
    if (!(assessment instanceof HTMLFormElement)) return [];
    return areas.flatMap((area, areaIndex) =>
      area.questions.map((_, questionIndex) => {
        const input = assessment.querySelector(`input[data-area="${areaIndex}"][data-question="${questionIndex}"]`);
        return {
          areaIndex,
          questionIndex,
          value: input instanceof HTMLInputElement ? Number(input.value) - 1 : 0,
        };
      }),
    );
  }

  function answeredInStep(step) {
    if (step >= areas.length) return 0;
    if (!(assessment instanceof HTMLFormElement)) return 0;
    return assessment.querySelectorAll(`input[data-area="${step}"][data-answered="true"]`).length;
  }

  function stepIsComplete(step) {
    if (step >= areas.length) return true;
    return answeredInStep(step) === areas[step].questions.length;
  }

  function setWizardError(message = "") {
    const error = document.querySelector("[data-wizard-error]");
    if (!(error instanceof HTMLElement)) return;
    error.textContent = message || "Responde las 3 preguntas de este paso para continuar.";
    error.hidden = !message;
  }

  function updateStepControls() {
    const next = document.querySelector("[data-next-step]");
    const submit = document.querySelector("[data-submit-assessment]");
    const complete = stepIsComplete(currentStep);
    if (next instanceof HTMLButtonElement && currentStep < leadStep) {
      next.disabled = !complete;
      next.textContent = currentStep === areas.length - 1 ? "Continuar" : "Siguiente área";
    }
    if (submit instanceof HTMLButtonElement && currentStep === leadStep) submit.disabled = false;
  }

  function updateProgress(value = currentStep, completed = false) {
    document.querySelectorAll("[data-progress-bar]").forEach((bar) => {
      if (bar instanceof HTMLElement) {
        const width = completed ? 100 : Math.min(96, Math.round((value / areas.length) * 100));
        bar.style.width = `${width}%`;
      }
    });
  }

  function showStep(step) {
    currentStep = Math.max(0, Math.min(step, leadStep));
    document.querySelectorAll("[data-step]").forEach((panel) => {
      if (panel instanceof HTMLElement) {
        panel.hidden = currentStep >= areas.length || panel.dataset.step !== String(currentStep);
      }
    });

    const prev = document.querySelector("[data-prev-step]");
    const next = document.querySelector("[data-next-step]");
    const submit = document.querySelector("[data-submit-assessment]");
    const lead = document.querySelector("[data-assessment-lead]");

    if (prev instanceof HTMLButtonElement) prev.disabled = currentStep === 0;
    if (next instanceof HTMLButtonElement) next.hidden = currentStep === leadStep;
    if (submit instanceof HTMLButtonElement) submit.hidden = currentStep !== leadStep;
    if (lead instanceof HTMLElement) lead.hidden = currentStep !== leadStep;
    setWizardError("");
    updateProgress(currentStep);
    updateStepControls();
  }

  if (assessment instanceof HTMLFormElement) {
    const prev = document.querySelector("[data-prev-step]");
    const next = document.querySelector("[data-next-step]");

    showStep(0);

    assessment.querySelectorAll('input[type="range"][data-area]').forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      const updateRange = () => {
        input.dataset.answered = input.value !== "0" ? "true" : "false";
        const label = input.closest(".range-answer")?.querySelector("[data-range-label]");
        if (label) label.textContent = rangeLabels[Number(input.value)];
        updateStepControls();
      };
      input.addEventListener("input", updateRange);
      input.addEventListener("change", updateRange);
    });

    assessment.addEventListener("input", () => {
      window.tdTrackEvent?.("inicio_autoevaluacion");
      setWizardError("");
    });

    prev?.addEventListener("click", () => showStep(currentStep - 1));

    next?.addEventListener("click", () => {
      if (!stepIsComplete(currentStep)) {
        setWizardError("Responde las 3 preguntas de este paso para continuar.");
        return;
      }
      showStep(currentStep + 1);
      assessment.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    document.querySelectorAll("[data-started-at]").forEach((input) => {
      if (input instanceof HTMLInputElement) input.value = String(Date.now());
    });

    assessment.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (currentStep !== leadStep) {
        setWizardError("Completa todas las áreas antes de calcular el resultado.");
        return;
      }
      if (!assessment.reportValidity()) {
        return;
      }
      const submit = document.querySelector("[data-submit-assessment]");
      const status = document.querySelector("[data-assessment-status]");
      if (submit instanceof HTMLButtonElement) submit.disabled = true;
      if (status instanceof HTMLElement) status.textContent = "Procesando diagnóstico...";

      const scores = areas.map((_, areaIndex) => {
        return [...assessment.querySelectorAll(`input[data-area="${areaIndex}"]`)].reduce((sum, input) => sum + (Number(input.value) - 1), 0);
      });
      state.areaScores = scores;
      state.total = scores.reduce((sum, score) => sum + score, 0);
      state.percent = Math.round((state.total / 81) * 100);
      const interpretation = getInterpretation(state.total);
      state.level = interpretation.level;

      try {
        const formData = new FormData(assessment);
        const response = await postLead("diagnostic", {
          ...leadPayloadFromForm(formData),
          answers: collectAnswers(),
        });
        const title = response.emailDelivered === false ? "Recibimos tu diagnóstico." : "Te enviamos el diagnóstico por email.";
        document.querySelector("[data-result-title]").textContent = title;
        document.querySelector("[data-result-text]").textContent =
          response.message || "Guardamos tus respuestas y generamos el diagnóstico desde el backend. Revisa tu correo en unos minutos.";
        updateProgress(areas.length, true);
        assessment.hidden = true;
        if (result instanceof HTMLElement) result.hidden = false;
        result?.scrollIntoView({ behavior: "smooth", block: "start" });
        window.tdTrackEvent?.("finalizacion_autoevaluacion", { score: state.total });
      } catch (error) {
        if (status instanceof HTMLElement) status.textContent = error instanceof Error ? error.message : "No se pudo enviar el diagnóstico.";
        if (submit instanceof HTMLButtonElement) submit.disabled = false;
      }
    });
  }

  document.querySelector("[data-reset-assessment]")?.addEventListener("click", () => {
    if (!(assessment instanceof HTMLFormElement)) return;
    assessment.reset();
    state.areaScores = [];
    state.total = 0;
    state.percent = 0;
    state.level = "";
    const submit = document.querySelector("[data-submit-assessment]");
    const status = document.querySelector("[data-assessment-status]");
    if (submit instanceof HTMLButtonElement) submit.disabled = false;
    if (status instanceof HTMLElement) status.textContent = "";
    assessment.querySelectorAll('input[type="range"][data-area]').forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      input.value = "0";
      input.dataset.answered = "false";
      const label = input.closest(".range-answer")?.querySelector("[data-range-label]");
      if (label) label.textContent = rangeLabels[0];
    });
    if (result instanceof HTMLElement) result.hidden = true;
    assessment.hidden = false;
    setWizardError("");
    showStep(0);
    assessment.querySelectorAll("[data-started-at]").forEach((input) => {
      if (input instanceof HTMLInputElement) input.value = String(Date.now());
    });
    assessment.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  document.querySelector("[data-method-form]")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    const form = event.currentTarget;
    if (!(form instanceof HTMLFormElement)) return;
    const button = form.querySelector("button[type='submit']");
    const status = document.querySelector("[data-method-status]");
    if (button instanceof HTMLButtonElement) button.disabled = true;
    if (status instanceof HTMLElement) status.textContent = "Enviando método...";
    try {
      const response = await postLead("method", leadPayloadFromForm(new FormData(form)));
      if (status instanceof HTMLElement) status.textContent = response.message || "Método enviado. Revisa tu email en unos minutos.";
      form.reset();
      form.querySelectorAll("[data-started-at]").forEach((input) => {
        if (input instanceof HTMLInputElement) input.value = String(Date.now());
      });
      window.tdTrackEvent?.("descarga_metodo");
    } catch (error) {
      if (status instanceof HTMLElement) status.textContent = error instanceof Error ? error.message : "No se pudo enviar el método.";
    } finally {
      if (button instanceof HTMLButtonElement) button.disabled = false;
    }
  });
</script>
