---
import { assessmentAreas } from "@/data/selfAssessment";
import { siteConfig } from "@/config/site";
import { withBase } from "@/utils/paths";
---

<section id="autoevaluacion" class="section section-accent">
  <div class="section-head">
    <span class="eyebrow">Autoevaluación</span>
    <h2>Haz la Autoevaluación del Impuesto Operativo</h2>
    <p>Responde el wizard completo y verás tu resultado al instante. Después podrás descargar tu diagnóstico y acceder al marco de trabajo completo del método.</p>
  </div>

  <form class="assessment" data-assessment>
    {assessmentAreas.map((area, areaIndex) => (
      <fieldset class="area-block" data-step={areaIndex} hidden={areaIndex !== 0}>
        <legend class="sr-only">{area.name}</legend>
        <div class="wizard-head" aria-live="polite">
          <div>
            <span class="eyebrow">Paso {areaIndex + 1} de {assessmentAreas.length}</span>
            <h3>{area.name}</h3>
          </div>
          <div class="wizard-progress" aria-hidden="true">
            <i data-progress-bar style="width: 0%"></i>
          </div>
        </div>
        {area.questions.map((question, questionIndex) => {
          const name = `area-${areaIndex}-q-${questionIndex}`;
          return (
            <div class="question">
              <p>{question}</p>
              <div class="range-answer">
                <strong data-range-label>Sin seleccionar</strong>
                <input
                  type="range"
                  name={name}
                  min="0"
                  max="4"
                  step="1"
                  value="0"
                  data-area={areaIndex}
                  data-question={questionIndex}
                  data-answered="false"
                  aria-label={question}
                />
              </div>
            </div>
          );
        })}
      </fieldset>
    ))}

    <p class="wizard-error" data-wizard-error hidden>Responde las 3 preguntas de este paso para continuar.</p>
    <div class="form-actions">
      <button class="btn btn-secondary" type="button" data-prev-step>Anterior</button>
      <button class="btn btn-primary" type="button" data-next-step>Siguiente área</button>
      <button class="btn btn-primary" type="submit" data-submit-assessment hidden>Calcular mi impuesto operativo</button>
    </div>
  </form>

  <section class="result-panel" data-result hidden aria-live="polite">
    <div class="result-summary">
      <div>
        <span class="eyebrow">Resultado inicial</span>
        <h3 data-result-title></h3>
        <p data-result-text></p>
        <p class="muted">Esta autoevaluación no sustituye un diagnóstico completo. Sirve para darte una primera lectura y detectar dónde puede haber impuesto operativo.</p>
      </div>
      <div class="score-card">
        <strong data-score-total>0/81</strong>
        <span data-score-percent>0%</span>
      </div>
    </div>
    <div class="bars" data-bars></div>
    <div class="weak-areas">
      <h4>3 áreas más flojas</h4>
      <ol data-weak-areas></ol>
    </div>
    <div class="result-actions">
      <a class="btn btn-primary" data-event="click_reservar_llamada" href={siteConfig.bookingUrl} target="_blank" rel="noreferrer">Reservar llamada para revisar mi resultado</a>
      <button class="btn btn-secondary" type="button" data-reset-assessment>Reiniciar diagnóstico</button>
    </div>

    <div class="lead-capture">
      <h3>Descargar mi diagnóstico</h3>
      <p>Deja tus datos para generar una versión imprimible del resultado. Sin backend configurado, se abrirá un informe local para imprimir o guardar como PDF.</p>
      <form data-diagnostic-form action={siteConfig.formEndpoint} method="post">
        <div class="form-grid">
          <label>Nombre<input required name="nombre" autocomplete="name" /></label>
          <label>Email<input required type="email" name="email" autocomplete="email" /></label>
          <label>Empresa<input required name="empresa" autocomplete="organization" /></label>
          <label>Cargo<input required name="cargo" autocomplete="organization-title" /></label>
        </div>
        <label class="check"><input required type="checkbox" name="privacidad" /> <span>Acepto la <a href={withBase("/politica-privacidad")}>política de privacidad</a>.</span></label>
        <label class="check"><input type="checkbox" name="comunicaciones" /> Quiero recibir comunicaciones relacionadas con el diagnóstico operativo.</label>
        <input type="hidden" name="score_total" data-hidden-score />
        <input type="hidden" name="areas" data-hidden-areas />
        <button class="btn btn-secondary" type="submit" data-event="descarga_diagnostico">Descargar mi diagnóstico</button>
      </form>
    </div>

    <div class="method-download">
      <div class="method-copy">
        <span class="eyebrow">Marco de trabajo</span>
        <h3>Descarga el método completo</h3>
        <p>Si quieres revisar el método completo con todas las áreas de auditoría, puedes descargar una versión resumida del marco de trabajo.</p>
        <img class="method-scorecard" src={withBase("/scorecard-placeholder.svg")} alt="Vista previa del scorecard del método" loading="lazy" width="560" height="360" />
      </div>
      <form class="compact-form" data-method-form action={siteConfig.formEndpoint} method="post">
        <label>Nombre<input required name="nombre" /><small>Obligatorio.</small></label>
        <label>Email<input required type="email" name="email" /><small>Obligatorio. Lo usamos para enviarte o habilitar la descarga.</small></label>
        <label>Empresa<input name="empresa" /><small>Opcional.</small></label>
        <label class="check"><input required type="checkbox" name="privacidad" /> <span>Acepto la <a href={withBase("/politica-privacidad")}>política de privacidad</a>.</span></label>
        <button class="btn btn-primary" type="submit" data-event="descarga_metodo">Descargar método completo</button>
        <p class="form-help">Archivo preparado en {siteConfig.methodPdfPath}. Si todavía no existe, coloca ahí el PDF cuando esté listo.</p>
      </form>
    </div>
  </section>
</section>

<script define:vars={{ areas: assessmentAreas, formEndpoint: siteConfig.formEndpoint, methodPdfPath: siteConfig.methodPdfPath }}>
  const assessment = document.querySelector("[data-assessment]");
  const result = document.querySelector("[data-result]");
  const state = { areaScores: [], total: 0, percent: 0, level: "" };
  let currentStep = 0;
  const rangeLabels = [
    "Sin seleccionar",
    "Crítico / reactivo / inexistente",
    "Informal / dependiente de personas",
    "Parcialmente estructurado",
    "Estructurado / visible / gobernado",
  ];

  function getInterpretation(total) {
    if (total <= 27) {
      return {
        level: "Tu operación depende demasiado de esfuerzo humano clave.",
        text: "La lectura de ROI es clara: ahora mismo el coste probablemente no está solo en herramientas o sueldos, sino en tiempo directivo perdido, decisiones reactivas y capacidad de crecimiento bloqueada. Si eres CEO, es probable que estés sosteniendo demasiadas cosas con memoria, criterio personal y urgencias diarias. La prioridad no es añadir más complejidad, sino recuperar control operativo y liberar horas de dirección.",
      };
    }
    if (total <= 54) {
      return {
        level: "Tu empresa funciona, pero todavía paga fricción con tiempo del CEO.",
        text: "La empresa probablemente ya tiene cierta estructura, pero hay áreas que consumen más energía de la que deberían. El ROI está en atacar los puntos donde una mejora pequeña puede devolver foco, reducir interrupciones y hacer que el crecimiento pese menos. No parece un problema de trabajar más, sino de decidir mejor dónde poner orden primero.",
      };
    }
    return {
      level: "Hay base operativa, pero el ROI puede estar en afinar los cuellos débiles.",
      text: "Tu empresa muestra señales de gobernanza. Eso no significa que no haya impuesto operativo: significa que conviene mirar con precisión qué áreas están limitando delegación, escalabilidad o velocidad de decisión. Para un CEO, el retorno puede estar en recuperar tiempo de calidad, quitar ruido del día a día y acercar la operación al nivel que exige la madurez actual del negocio.",
    };
  }

  function renderBars(scores) {
    const bars = document.querySelector("[data-bars]");
    if (!bars) return;
    bars.innerHTML = scores
      .map((score, index) => {
        const width = Math.round((score / 9) * 100);
        return `<div class="bar-row"><span>${areas[index].name}</span><div class="bar-track"><i style="width:${width}%"></i></div><strong>${score}/9</strong></div>`;
      })
      .join("");
  }

  function updateHiddenFields() {
    const scoreInput = document.querySelector("[data-hidden-score]");
    const areasInput = document.querySelector("[data-hidden-areas]");
    if (scoreInput instanceof HTMLInputElement) scoreInput.value = String(state.total);
    if (areasInput instanceof HTMLInputElement) {
      areasInput.value = areas.map((area, index) => `${area.name}: ${state.areaScores[index]}/9`).join(" | ");
    }
  }

  function answeredInStep(step) {
    if (!(assessment instanceof HTMLFormElement)) return 0;
    return assessment.querySelectorAll(`input[data-area="${step}"][data-answered="true"]`).length;
  }

  function stepIsComplete(step) {
    return answeredInStep(step) === areas[step].questions.length;
  }

  function setWizardError(message = "") {
    const error = document.querySelector("[data-wizard-error]");
    if (!(error instanceof HTMLElement)) return;
    error.textContent = message || "Responde las 3 preguntas de este paso para continuar.";
    error.hidden = !message;
  }

  function updateStepControls() {
    const next = document.querySelector("[data-next-step]");
    const submit = document.querySelector("[data-submit-assessment]");
    const complete = stepIsComplete(currentStep);
    if (next instanceof HTMLButtonElement && currentStep !== areas.length - 1) next.disabled = !complete;
    if (submit instanceof HTMLButtonElement && currentStep === areas.length - 1) submit.disabled = !complete;
  }

  function updateProgress(value = currentStep) {
    document.querySelectorAll("[data-progress-bar]").forEach((bar) => {
      if (bar instanceof HTMLElement) {
        bar.style.width = `${Math.round((value / areas.length) * 100)}%`;
      }
    });
  }

  function showStep(step) {
    currentStep = Math.max(0, Math.min(step, areas.length - 1));
    document.querySelectorAll("[data-step]").forEach((panel) => {
      if (panel instanceof HTMLElement) {
        panel.hidden = panel.dataset.step !== String(currentStep);
      }
    });

    const prev = document.querySelector("[data-prev-step]");
    const next = document.querySelector("[data-next-step]");
    const submit = document.querySelector("[data-submit-assessment]");

    if (prev instanceof HTMLButtonElement) prev.disabled = currentStep === 0;
    if (next instanceof HTMLButtonElement) next.hidden = currentStep === areas.length - 1;
    if (submit instanceof HTMLButtonElement) submit.hidden = currentStep !== areas.length - 1;
    setWizardError("");
    updateProgress(currentStep);
    updateStepControls();
  }

  function buildPrintableReport(formData) {
    const company = formData.get("empresa") || "Empresa sin indicar";
    const date = new Date().toLocaleDateString("es-ES");
    const printScript = "<" + "script>window.print()<" + "/script>";
    const weak = [...state.areaScores]
      .map((score, index) => ({ score, name: areas[index].name }))
      .sort((a, b) => a.score - b.score)
      .slice(0, 3);
    return `<!doctype html><html lang="es"><head><meta charset="UTF-8"><title>Diagnóstico operativo - ${company}</title><style>body{font-family:Arial,sans-serif;color:#17211d;margin:40px;line-height:1.5}h1{font-size:28px}table{width:100%;border-collapse:collapse;margin:24px 0}td,th{border:1px solid #cfd8d3;padding:10px;text-align:left}.cta{margin-top:28px;padding:18px;border:1px solid #17211d}</style></head><body><h1>Diagnóstico inicial del Impuesto Operativo</h1><p><strong>Empresa:</strong> ${company}</p><p><strong>Fecha:</strong> ${date}</p><p><strong>Score total:</strong> ${state.total}/81 (${state.percent}%)</p><h2>${state.level}</h2><p>${getInterpretation(state.total).text}</p><table><thead><tr><th>Área</th><th>Puntuación</th></tr></thead><tbody>${areas.map((area, index) => `<tr><td>${area.name}</td><td>${state.areaScores[index]}/9</td></tr>`).join("")}</tbody></table><h2>3 áreas más débiles</h2><ol>${weak.map((item) => `<li>${item.name}: ${item.score}/9</li>`).join("")}</ol><h2>Recomendación general</h2><p>Revisar primero las áreas con menor puntuación, detectar dependencias críticas, ordenar responsabilidades y priorizar cambios que reduzcan fricción antes de añadir más herramientas o personas.</p><div class="cta"><strong>CTA:</strong> Reservar llamada gratuita de 30 minutos para revisar el resultado.</div>${printScript}</body></html>`;
  }

  if (assessment instanceof HTMLFormElement) {
    const prev = document.querySelector("[data-prev-step]");
    const next = document.querySelector("[data-next-step]");

    showStep(0);

    assessment.querySelectorAll('input[type="range"][data-area]').forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      const updateRange = () => {
        input.dataset.answered = input.value !== "0" ? "true" : "false";
        const label = input.closest(".range-answer")?.querySelector("[data-range-label]");
        if (label) label.textContent = rangeLabels[Number(input.value)];
        updateStepControls();
      };
      input.addEventListener("input", updateRange);
      input.addEventListener("change", updateRange);
    });

    assessment.addEventListener("input", () => {
      window.tdTrackEvent?.("inicio_autoevaluacion");
      setWizardError("");
    });

    prev?.addEventListener("click", () => showStep(currentStep - 1));

    next?.addEventListener("click", () => {
      if (!stepIsComplete(currentStep)) {
        setWizardError("Responde las 3 preguntas de este paso para continuar.");
        return;
      }
      showStep(currentStep + 1);
      assessment.scrollIntoView({ behavior: "smooth", block: "start" });
    });

    assessment.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!stepIsComplete(currentStep)) {
        setWizardError("Responde las 3 preguntas de este paso para calcular el resultado.");
        return;
      }
      const scores = areas.map((_, areaIndex) => {
        return [...assessment.querySelectorAll(`input[data-area="${areaIndex}"]`)].reduce((sum, input) => sum + (Number(input.value) - 1), 0);
      });
      state.areaScores = scores;
      state.total = scores.reduce((sum, score) => sum + score, 0);
      state.percent = Math.round((state.total / 81) * 100);
      const interpretation = getInterpretation(state.total);
      state.level = interpretation.level;

      document.querySelector("[data-result-title]").textContent = interpretation.level;
      document.querySelector("[data-result-text]").textContent = interpretation.text;
      document.querySelector("[data-score-total]").textContent = `${state.total}/81`;
      document.querySelector("[data-score-percent]").textContent = `${state.percent}%`;
      renderBars(scores);

      const weakList = document.querySelector("[data-weak-areas]");
      if (weakList) {
        weakList.innerHTML = scores
          .map((score, index) => ({ score, name: areas[index].name }))
          .sort((a, b) => a.score - b.score)
          .slice(0, 3)
          .map((item) => `<li>${item.name} <strong>${item.score}/9</strong></li>`)
          .join("");
      }
      updateHiddenFields();
      updateProgress(areas.length);
      assessment.hidden = true;
      if (result instanceof HTMLElement) result.hidden = false;
      result?.scrollIntoView({ behavior: "smooth", block: "start" });
      window.tdTrackEvent?.("finalizacion_autoevaluacion", { score: state.total });
    });
  }

  document.querySelector("[data-reset-assessment]")?.addEventListener("click", () => {
    if (!(assessment instanceof HTMLFormElement)) return;
    assessment.reset();
    state.areaScores = [];
    state.total = 0;
    state.percent = 0;
    state.level = "";
    assessment.querySelectorAll('input[type="range"][data-area]').forEach((input) => {
      if (!(input instanceof HTMLInputElement)) return;
      input.value = "0";
      input.dataset.answered = "false";
      const label = input.closest(".range-answer")?.querySelector("[data-range-label]");
      if (label) label.textContent = rangeLabels[0];
    });
    if (result instanceof HTMLElement) result.hidden = true;
    assessment.hidden = false;
    setWizardError("");
    showStep(0);
    assessment.scrollIntoView({ behavior: "smooth", block: "start" });
  });

  document.querySelector("[data-diagnostic-form]")?.addEventListener("submit", (event) => {
    if (!formEndpoint || formEndpoint.includes("INSERTAR")) {
      event.preventDefault();
      const win = window.open("", "_blank");
      if (!win) return;
      win.document.write(buildPrintableReport(new FormData(event.currentTarget)));
      win.document.close();
    }
  });

  document.querySelector("[data-method-form]")?.addEventListener("submit", (event) => {
    if (!formEndpoint || formEndpoint.includes("INSERTAR")) {
      event.preventDefault();
      window.location.href = methodPdfPath;
    }
  });
</script>
