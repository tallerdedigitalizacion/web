---
import { siteConfig } from "@/config/site";
import { withBase } from "@/utils/paths";

const {
  bookingEvent = "reservar_click",
  brandHref = "/",
  navItems = [],
  showBooking = true,
  lang = "es",
  bookingHref = siteConfig.bookingUrl,
} = Astro.props;
const resolveHref = (href: string) => (href.startsWith("/") ? (import.meta.env.DEV ? href : withBase(href)) : href);
const brandTarget = resolveHref(brandHref);
const resolvedNavItems = navItems.map(([label, href]: [string, string]) => [label, resolveHref(href)]);
const isEnglish = lang === "en";
const labels = {
  home: isEnglish ? "Home" : "Inicio",
  nav: isEnglish ? "Primary navigation" : "Navegación principal",
  book: isEnglish ? "Book a call" : "Reservar llamada",
  openMenu: isEnglish ? "Open menu" : "Abrir menú",
  closeMenu: isEnglish ? "Close menu" : "Cerrar menú",
  mobileNav: isEnglish ? "Mobile navigation" : "Navegación móvil",
};
---

<header class="site-header">
  <a class="brand" href={brandTarget} aria-label={labels.home}>
    <img src={withBase(siteConfig.logo)} alt="Taller de Digitalización" width="48" height="48" />
  </a>
  {resolvedNavItems.length > 0 && (
    <nav class="desktop-nav" aria-label={labels.nav}>
      {resolvedNavItems.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  )}
  <div class="header-actions">
    {showBooking && <a class="btn btn-small btn-primary" data-event={bookingEvent} href={bookingHref} target="_blank" rel="noreferrer">{labels.book}</a>}
    {resolvedNavItems.length > 0 && (
      <button class="menu-toggle" type="button" aria-label={labels.openMenu} aria-expanded="false" aria-controls="mobile-menu" data-label-open={labels.openMenu} data-label-close={labels.closeMenu}>
        <span></span>
        <span></span>
        <span></span>
      </button>
    )}
  </div>
  {resolvedNavItems.length > 0 && (
    <nav id="mobile-menu" class="mobile-nav" aria-label={labels.mobileNav} hidden>
      {resolvedNavItems.map(([label, href]) => <a href={href}>{label}</a>)}
    </nav>
  )}
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const menu = document.querySelector("#mobile-menu");
  const header = document.querySelector(".site-header");

  if (toggle instanceof HTMLButtonElement && menu instanceof HTMLElement && header instanceof HTMLElement) {
    const closeMenu = () => {
      menu.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", toggle.dataset.labelOpen || "Abrir menú");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      menu.hidden = isOpen;
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? toggle.dataset.labelOpen || "Abrir menú" : toggle.dataset.labelClose || "Cerrar menú");
    });

    menu.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen && !header.contains(target)) closeMenu();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  }
</script>
