---
import { siteConfig } from "@/config/site";
import { withBase } from "@/utils/paths";

const homeHref = import.meta.env.DEV ? "/" : withBase("/");
const navItems = [
  ["Problema", `${homeHref}#problema`],
  ["Autoevaluación", `${homeHref}#autoevaluacion`],
  ["Diagnóstico", `${homeHref}#diagnostico`],
  ["Cómo funciona", `${homeHref}#como-funciona`],
  ["FAQ", `${homeHref}#faq`],
];
---

<header class="site-header">
  <a class="brand" href={homeHref} aria-label="Inicio">
    <img src={withBase(siteConfig.logo)} alt="Taller de Digitalización" width="48" height="48" />
  </a>
  <nav class="desktop-nav" aria-label="Navegación principal">
    {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
  </nav>
  <div class="header-actions">
    <a class="btn btn-small btn-primary" data-event="click_reservar_llamada" href={siteConfig.bookingUrl} target="_blank" rel="noreferrer">Reservar llamada</a>
    <button class="menu-toggle" type="button" aria-label="Abrir menú" aria-expanded="false" aria-controls="mobile-menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
  <nav id="mobile-menu" class="mobile-nav" aria-label="Navegación móvil" hidden>
    {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
  </nav>
</header>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const menu = document.querySelector("#mobile-menu");
  const header = document.querySelector(".site-header");

  if (toggle instanceof HTMLButtonElement && menu instanceof HTMLElement && header instanceof HTMLElement) {
    const closeMenu = () => {
      menu.hidden = true;
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Abrir menú");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      menu.hidden = isOpen;
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Abrir menú" : "Cerrar menú");
    });

    menu.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      if (isOpen && !header.contains(target)) closeMenu();
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });
  }
</script>
