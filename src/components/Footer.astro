---
import { siteConfig } from "@/config/site";
import { withBase } from "@/utils/paths";

const { lang = "es" } = Astro.props;
const isEnglish = lang === "en";
---

<footer class="site-footer">
  <div class="footer-brand">
    <img src={withBase(siteConfig.logo)} alt="Taller de Digitalización" width="48" height="48" loading="lazy" />
    <div>
      <strong>{siteConfig.name}</strong>
      <p>{isEnglish ? "Technical diagnosis and fixes for websites and business operations." : "Diagnóstico y reducción de caos operativo para PyMEs."}</p>
    </div>
  </div>
  <nav aria-label={isEnglish ? "Footer links" : "Enlaces de pie de página"}>
    <a data-event="click_linktree" href={siteConfig.linktreeUrl} target="_blank" rel="noreferrer">{isEnglish ? "Link hub" : "Ver hub de enlaces"}</a>
    <a href={withBase("/aviso-legal")}>{isEnglish ? "Legal notice" : "Aviso legal"}</a>
    <a href={withBase("/politica-privacidad")}>{isEnglish ? "Privacy policy" : "Política de privacidad"}</a>
    <a href={withBase("/politica-cookies")}>{isEnglish ? "Cookie policy" : "Política de cookies"}</a>
  </nav>
</footer>
