---
import { siteConfig } from "@/config/site";

const { lang = "es" } = Astro.props;
const isEnglish = lang === "en";
---

<div class="cookie-banner" data-cookie-banner hidden>
  <div>
    <strong>Cookies</strong>
    <p>{isEnglish ? "We use necessary cookies to keep the site working. Analytics only load if you accept them." : "Usamos cookies necesarias para que la web funcione. Las analíticas solo se cargan si las aceptas."}</p>
  </div>
  <div class="cookie-actions">
    <button class="btn btn-small btn-secondary" type="button" data-cookie-choice="reject">{isEnglish ? "Reject" : "Rechazar"}</button>
    <button class="btn btn-small btn-secondary" type="button" data-cookie-choice="necessary">{isEnglish ? "Necessary only" : "Aceptar necesarias"}</button>
    <button class="btn btn-small btn-primary" type="button" data-cookie-choice="all">{isEnglish ? "Accept all" : "Aceptar todas"}</button>
  </div>
</div>

<script define:vars={{ gaId: siteConfig.googleAnalyticsId }}>
  const consentKey = "td_cookie_consent";
  const banner = document.querySelector("[data-cookie-banner]");
  const eventAliases = {
    click_reservar_llamada: "reservar_click",
    click_whatsapp: "whatsapp_click",
    click_telefono: "telefono_click",
  };

  function normalizeEventName(name) {
    return eventAliases[name] || name;
  }

  function getClickEventName(target) {
    const explicitEvent = target.dataset.event;
    if (explicitEvent) return normalizeEventName(explicitEvent);

    const href = target instanceof HTMLAnchorElement ? target.href : "";
    if (href.startsWith("tel:")) return "telefono_click";
    if (href.includes("wa.me/") || href.includes("api.whatsapp.com/")) return "whatsapp_click";
    if (href.includes("calendly.com/tallerdedigitalizacion") || href.includes("cal.com/taller-de-digitalizacion")) return "reservar_click";
    return "";
  }

  function getClickEventParams(target) {
    const href = target instanceof HTMLAnchorElement ? target.href : "";
    return {
      link_url: href || undefined,
      link_text: target.textContent?.trim().replace(/\s+/g, " ").slice(0, 120) || undefined,
      page_path: window.location.pathname,
      page_location: window.location.href,
    };
  }

  function trackEvent(name, params = {}) {
    const eventName = normalizeEventName(name);
    window.dataLayer = window.dataLayer || [];
    if (typeof window.gtag === "function") {
      window.gtag("event", eventName, params);
    }
  }

  window.tdTrackEvent = trackEvent;

  function preserveAttributionParams() {
    const params = new URLSearchParams(window.location.search);
    const attributionEntries = [...params.entries()].filter(([key]) => {
      const normalizedKey = key.toLowerCase();
      return normalizedKey.startsWith("utm_") || ["gclid", "gbraid", "wbraid"].includes(normalizedKey);
    });

    if (attributionEntries.length === 0) return;

    document.querySelectorAll('a[href*="calendly.com/tallerdedigitalizacion"], a[href*="cal.com/taller-de-digitalizacion"], a[href*="wa.me/"], a[href*="api.whatsapp.com/"]').forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const url = new URL(link.href);
      attributionEntries.forEach(([key, value]) => {
        if (!url.searchParams.has(key)) url.searchParams.set(key, value);
      });
      link.href = url.toString();
    });
  }

  function loadAnalytics() {
    if (!gaId || gaId.includes("INSERTAR")) return;
    if (document.querySelector(`script[src*="${gaId}"]`)) return;
    const script = document.createElement("script");
    script.async = true;
    script.src = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
    document.head.appendChild(script);
    window.dataLayer = window.dataLayer || [];
    window.gtag = function gtag() {
      window.dataLayer.push(arguments);
    };
    window.gtag("js", new Date());
    window.gtag("config", gaId, { anonymize_ip: true });
  }

  const currentConsent = localStorage.getItem(consentKey);
  preserveAttributionParams();
  if (currentConsent === "all") loadAnalytics();
  if (!currentConsent && banner instanceof HTMLElement) banner.hidden = false;

  document.querySelectorAll("[data-cookie-choice]").forEach((button) => {
    button.addEventListener("click", () => {
      const choice = button.getAttribute("data-cookie-choice");
      localStorage.setItem(consentKey, choice || "necessary");
      if (banner instanceof HTMLElement) banner.hidden = true;
      if (choice === "all") loadAnalytics();
      trackEvent(choice === "all" ? "aceptacion_cookies" : "rechazo_cookies", { choice });
    });
  });

  document.addEventListener("click", (event) => {
    const target = event.target instanceof Element ? event.target.closest("a, button") : null;
    if (target instanceof HTMLElement) {
      const eventName = getClickEventName(target);
      if (eventName) trackEvent(eventName, getClickEventParams(target));
    }
  });

  window.addEventListener("message", (event) => {
    if (typeof event.origin !== "string" || !event.origin.includes("calendly.com")) return;
    const eventName = event.data?.event;
    if (eventName === "calendly.event_scheduled") {
      trackEvent("reserva_completada", {
        page_path: window.location.pathname,
        page_location: window.location.href,
      });
    }
  });
</script>
