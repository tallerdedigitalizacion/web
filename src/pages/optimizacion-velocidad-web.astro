---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/config/site";

const title = "Web lenta: diagnóstico y optimización de velocidad | Taller de Digitalización";
const description = "¿Tu web va lenta? Diagnostico por qué y la acelero. Trabajo técnico, sin rehacerla. Reserva un diagnóstico gratis.";
const whatsappUrl = `https://wa.me/${siteConfig.whatsappNumber}?text=Hola,%20mi%20web%20va%20lenta`;
const googleReviewsUrl = "https://maps.app.goo.gl/iJYaupqoL8usLB6X7";

const costBullets = ["Se van antes de cargar", "Google te penaliza", "Menos contactos y ventas"];
const steps = [
  "Llamada de diagnóstico gratis (30 min)",
  "Te digo qué está mal y cuánto cuesta arreglarlo",
  "Lo acelero y lo verificamos con PageSpeed / Core Web Vitals",
];
const faqs = [
  ["¿Hace falta rehacer la web?", "No, optimizo lo que ya tienes."],
  ["¿En qué plataformas trabajas?", "WordPress y la mayoría de stacks."],
  ["¿Cuánto tarda?", "Te lo digo tras el diagnóstico."],
  ["¿Cuánto cuesta?", "Diagnóstico gratis; el arreglo, presupuesto cerrado tras la llamada."],
];

const navItems = [
  ["Coste", "#coste"],
  ["Qué hago", "#que-hago"],
  ["Cómo funciona", "#como-funciona"],
  ["Por qué yo", "#por-que-yo"],
  ["FAQ", "#faq"],
];

const speedReviews = [
  {
    name: "Jorge Signetti",
    date: "Hace 3 meses",
    text: "Muy buena atención, trabajo muy rápido y todo funciona sin problemas. Excelente soporte técnico. No intenta vender cosas innecesarias, va directo al problema y lo resuelve. Muy conforme.",
  },
  {
    name: "Noelia Preziosi",
    date: "Hace 3 meses",
    text: "Profesional, resolutivo y cercano. Da soluciones reales a problemas reales. Totalmente recomendable.",
  },
  {
    name: "Aldana",
    date: "Hace 3 meses",
    text: "Servicio súper ágil y profesional. Me ayudó mucho, ya que no tenía a nadie de confianza para estos temas de informática. Son muy claros y pacientes. Muy recomendable.",
  },
  {
    name: "Alan Signetti",
    date: "Hace 4 meses",
    text: "Tenía problemas con el correo y el ordenador y lo dejó todo funcionando en poco tiempo. Servicio serio y profesional.",
  },
  {
    name: "José Luis Rivera",
    date: "Hace 4 meses",
    text: "Muy conforme con el servicio técnico y muy eficaz y preciso para resolver problemas tecnológicos y en especial a distancia un genio.",
  },
  {
    name: "Camilo Arnedo",
    date: "Hace 4 meses",
    text: "Soporte informático claro y honesto. No intenta vender cosas innecesarias, solo arreglar lo que hace falta. Muy conforme.",
  },
  {
    name: "Akiwifi Girona Sud",
    date: "Hace 4 meses",
    text: "Servicio muy profesional y cercano. Explican las cosas de forma clara, sin complicaciones ni palabras raras. Me ayudaron a encontrar una solución rápida y eficaz justo cuando lo necesitaba. Da mucha confianza trabajar con un equipo así.",
  },
  {
    name: "Nimbus Telecom S.L.",
    date: "Hace 4 meses",
    text: "Atención excelente y trato muy humano. Se nota la experiencia y las ganas de ayudar de verdad. Resolvieron el problema con rapidez y me explicaron todo de forma sencilla. Totalmente recomendables.",
  },
  {
    name: "Vanessa Cortés",
    date: "Hace 4 meses",
    text: "Me dio soporte informático cuando lo necesitaba y lo solucionó rápido. Trato cercano y directo. Da mucha tranquilidad tener a alguien así.",
  },
  {
    name: "AAINJAA Dirección",
    date: "Hace 4 meses",
    text: "Un servicio excelente, una atención amable y en cuanto a mis necesidades, muy precisos, claros y profesionales en la información. Muchas gracias Pablo y todo su equipo.",
  },
  {
    name: "Marcos Irazabal",
    date: "Hace 4 meses",
    text: "Muy buen servicio. Me ayudó a resolver un problema informático que llevaba tiempo dando vueltas. Rápido, claro y sin complicaciones. Recomendable.",
  },
  {
    name: "Patricia Leone",
    date: "Hace 4 meses",
    text: "Profesional y muy claro explicando. Se nota que sabe lo que hace y que busca soluciones prácticas, no marear con tecnicismos.",
  },
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/optimizacion-velocidad-web"
  headerBrandHref="/optimizacion-velocidad-web"
  headerNavItems={navItems}
  headerBookingEvent="reservar_click"
>
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">Optimización de velocidad web</span>
      <h1>¿Tu web tarda en cargar y estás perdiendo clientes por eso?</h1>
      <p class="hero-subtitle">Diagnostico por qué tu web va lenta y la acelero. Trabajo técnico, sin rehacerla entera y sin venderte marketing.</p>
      <div class="hero-actions">
        <a class="btn btn-primary" data-event="reservar_click" data-preserve-utm href={siteConfig.bookingUrl} target="_blank" rel="noreferrer">Reservar diagnóstico gratis (30 min)</a>
        <a class="btn btn-secondary" data-event="whatsapp_click" data-preserve-utm href={whatsappUrl} target="_blank" rel="noreferrer">
          <svg class="btn-icon" aria-hidden="true" viewBox="0 0 32 32" width="20" height="20">
            <path fill="currentColor" d="M16.02 3.2A12.66 12.66 0 0 0 5.1 22.28L3.6 28.8l6.66-1.56A12.65 12.65 0 1 0 16.02 3.2Zm0 22.9c-1.96 0-3.78-.56-5.34-1.54l-.38-.24-3.94.92.9-3.86-.25-.4a10.24 10.24 0 1 1 9.01 5.12Zm5.62-7.66c-.3-.16-1.82-.9-2.1-1-.28-.1-.48-.16-.68.16-.2.3-.78 1-.96 1.2-.18.2-.36.22-.66.08-.3-.16-1.28-.48-2.44-1.52-.9-.8-1.5-1.8-1.68-2.1-.18-.3-.02-.48.14-.64.14-.14.3-.36.46-.54.16-.18.2-.3.3-.5.1-.2.06-.38-.02-.54-.08-.16-.68-1.64-.94-2.24-.24-.58-.5-.5-.68-.5h-.58c-.2 0-.52.08-.8.38-.28.3-1.04 1.02-1.04 2.48s1.06 2.88 1.22 3.08c.16.2 2.1 3.2 5.08 4.48.7.3 1.26.48 1.7.62.72.22 1.36.2 1.88.12.58-.08 1.82-.74 2.08-1.46.26-.72.26-1.34.18-1.46-.08-.14-.28-.22-.58-.38Z"/>
          </svg>
          Escríbeme por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <section id="coste" class="section">
    <div class="section-head">
      <span class="eyebrow">El coste de una web lenta</span>
      <h2>La espera también factura.</h2>
      <p>Una web lenta pierde visitantes antes de que vean nada, baja tu posición en Google (Core Web Vitals) y reduce las conversiones. No es estético: es dinero que se va.</p>
    </div>
    <div class="tag-grid">
      {costBullets.map((item) => <span>{item}</span>)}
    </div>
  </section>

  <section id="que-hago" class="section section-split">
    <div>
      <span class="eyebrow">Qué hago</span>
      <h2>Diagnóstico técnico, arreglo medible.</h2>
      <p>Reservas una llamada de diagnóstico gratis. Te digo en concreto qué frena tu web (imágenes, caché, render, hosting, código) y qué se puede arreglar. Si encaja, te paso presupuesto y lo arreglo. Lo verificamos con métricas antes/después.</p>
    </div>
    <div class="honest-note">
      <span class="eyebrow">Frontera de nicho</span>
      <p>No vendo SEO de contenidos ni campañas. Soluciono el problema técnico.</p>
    </div>
  </section>

  <section id="como-funciona" class="section section-accent">
    <div class="section-head">
      <span class="eyebrow">Cómo funciona</span>
      <h2>3 pasos, sin vueltas.</h2>
    </div>
    <div class="steps">
      {steps.map((step, index) => (
        <article>
          <span class="step-number">{index + 1}</span>
          <h3>{step}</h3>
        </article>
      ))}
    </div>
  </section>

  <section id="por-que-yo" class="section">
    <div class="section-head">
      <span class="eyebrow">Por qué yo</span>
      <h2>Una persona técnica mirando el problema de frente.</h2>
      <p>15 años desarrollando y optimizando software. <a class="google-review-link" href={googleReviewsUrl} target="_blank" rel="noreferrer">
        <svg class="google-mark" aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
          <path fill="#FBBC05" d="M5.84 14.11a6.61 6.61 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.66-2.84Z"/>
          <path fill="#EA4335" d="M12 5.36c1.62 0 3.06.56 4.21 1.64l3.15-3.15A10.56 10.56 0 0 0 12 1 11 11 0 0 0 2.18 7.05l3.66 2.84C6.71 7.29 9.14 5.36 12 5.36Z"/>
        </svg>
        +10 reseñas en Google
      </a> y +1.000 seguidores en LinkedIn. Una persona real que te atiende, no una agencia que te deriva a un becario.</p>
    </div>
    <div class="reviews-carousel" data-reviews-carousel aria-label="Reseñas de Google">
      <div class="reviews-track" data-reviews-track>
        {speedReviews.map((review, index) => (
          <article class="review-card" data-review-card aria-label={`Reseña ${index + 1} de ${speedReviews.length}`}>
            <div class="review-meta">
              <strong>{review.name}</strong>
              <a class="review-source" href={googleReviewsUrl} target="_blank" rel="noreferrer">
                <svg class="google-mark" aria-hidden="true" viewBox="0 0 24 24" width="16" height="16">
                  <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.76h3.56c2.08-1.92 3.28-4.74 3.28-8.09Z"/>
                  <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.56-2.76c-.98.66-2.24 1.06-3.72 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84A11 11 0 0 0 12 23Z"/>
                  <path fill="#FBBC05" d="M5.84 14.11a6.61 6.61 0 0 1 0-4.22V7.05H2.18a11 11 0 0 0 0 9.9l3.66-2.84Z"/>
                  <path fill="#EA4335" d="M12 5.36c1.62 0 3.06.56 4.21 1.64l3.15-3.15A10.56 10.56 0 0 0 12 1 11 11 0 0 0 2.18 7.05l3.66 2.84C6.71 7.29 9.14 5.36 12 5.36Z"/>
                </svg>
                Reseña de Google · 5/5 · {review.date}
              </a>
            </div>
            <p>{review.text}</p>
          </article>
        ))}
      </div>
      <div class="carousel-controls">
        <button class="btn btn-secondary btn-small" type="button" data-review-prev aria-label="Ver reseña anterior">Anterior</button>
        <div class="carousel-dots" data-review-dots aria-label="Indicador de reseñas"></div>
        <button class="btn btn-secondary btn-small" type="button" data-review-next aria-label="Ver reseña siguiente">Siguiente</button>
      </div>
    </div>
  </section>

  <section id="faq" class="section">
    <div class="section-head">
      <span class="eyebrow">Preguntas frecuentes</span>
      <h2>Dudas habituales antes del diagnóstico.</h2>
    </div>
    <div class="faq-list">
      {faqs.map(([question, answer]) => (
        <details>
          <summary>{question}</summary>
          <p>{answer}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="section final-cta">
    <h2>Reserva el diagnóstico gratis y veamos qué está frenando tu web.</h2>
    <div class="hero-actions">
      <a class="btn btn-primary" data-event="reservar_click" data-preserve-utm href={siteConfig.bookingUrl} target="_blank" rel="noreferrer">Reservar diagnóstico gratis</a>
      <a class="btn btn-secondary" data-event="whatsapp_click" data-preserve-utm href={whatsappUrl} target="_blank" rel="noreferrer">
        <svg class="btn-icon" aria-hidden="true" viewBox="0 0 32 32" width="20" height="20">
          <path fill="currentColor" d="M16.02 3.2A12.66 12.66 0 0 0 5.1 22.28L3.6 28.8l6.66-1.56A12.65 12.65 0 1 0 16.02 3.2Zm0 22.9c-1.96 0-3.78-.56-5.34-1.54l-.38-.24-3.94.92.9-3.86-.25-.4a10.24 10.24 0 1 1 9.01 5.12Zm5.62-7.66c-.3-.16-1.82-.9-2.1-1-.28-.1-.48-.16-.68.16-.2.3-.78 1-.96 1.2-.18.2-.36.22-.66.08-.3-.16-1.28-.48-2.44-1.52-.9-.8-1.5-1.8-1.68-2.1-.18-.3-.02-.48.14-.64.14-.14.3-.36.46-.54.16-.18.2-.3.3-.5.1-.2.06-.38-.02-.54-.08-.16-.68-1.64-.94-2.24-.24-.58-.5-.5-.68-.5h-.58c-.2 0-.52.08-.8.38-.28.3-1.04 1.02-1.04 2.48s1.06 2.88 1.22 3.08c.16.2 2.1 3.2 5.08 4.48.7.3 1.26.48 1.7.62.72.22 1.36.2 1.88.12.58-.08 1.82-.74 2.08-1.46.26-.72.26-1.34.18-1.46-.08-.14-.28-.22-.58-.38Z"/>
        </svg>
        Escríbeme por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<script>
  const params = new URLSearchParams(window.location.search);
  const utmEntries = [...params.entries()].filter(([key]) => key.toLowerCase().startsWith("utm_"));

  if (utmEntries.length > 0) {
    document.querySelectorAll('[data-preserve-utm], a[href*="calendly.com/tallerdedigitalizacion"]').forEach((link) => {
      if (!(link instanceof HTMLAnchorElement)) return;
      const url = new URL(link.href);
      utmEntries.forEach(([key, value]) => {
        if (!url.searchParams.has(key)) url.searchParams.set(key, value);
      });
      link.href = url.toString();
    });
  }

  document.querySelectorAll(".faq-list details").forEach((item) => {
    item.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest("summary")) return;
      item.open = !item.open;
    });
  });

  const carousel = document.querySelector("[data-reviews-carousel]");
  const track = document.querySelector("[data-reviews-track]");
  const cards = [...document.querySelectorAll("[data-review-card]")];
  const prev = document.querySelector("[data-review-prev]");
  const next = document.querySelector("[data-review-next]");
  const dots = document.querySelector("[data-review-dots]");
  let activeReview = 0;
  let scrollTimer;

  function renderDots() {
    if (!(dots instanceof HTMLElement)) return;
    dots.innerHTML = cards
      .map((_, index) => `<button type="button" aria-label="Ver reseña ${index + 1}" data-review-dot="${index}"></button>`)
      .join("");
  }

  function setActiveReview(index) {
    activeReview = (index + cards.length) % cards.length;
    dots?.querySelectorAll("[data-review-dot]").forEach((dot) => {
      dot.toggleAttribute("aria-current", dot.getAttribute("data-review-dot") === String(activeReview));
    });
  }

  function showReview(index) {
    if (!(track instanceof HTMLElement) || cards.length === 0) return;
    setActiveReview(index);
    const card = cards[activeReview];
    track.scrollTo({ left: card.offsetLeft - track.offsetLeft, behavior: "smooth" });
  }

  function syncReviewFromScroll() {
    if (!(track instanceof HTMLElement) || cards.length === 0) return;
    const nearestIndex = cards.reduce((nearest, card, index) => {
      const currentDistance = Math.abs(card.getBoundingClientRect().left - track.getBoundingClientRect().left);
      const nearestDistance = Math.abs(cards[nearest].getBoundingClientRect().left - track.getBoundingClientRect().left);
      return currentDistance < nearestDistance ? index : nearest;
    }, 0);
    setActiveReview(nearestIndex);
  }

  if (carousel && track && cards.length) {
    renderDots();
    showReview(0);

    track.addEventListener("scroll", () => {
      window.clearTimeout(scrollTimer);
      scrollTimer = window.setTimeout(syncReviewFromScroll, 80);
    });
    prev?.addEventListener("click", () => showReview(activeReview - 1));
    next?.addEventListener("click", () => showReview(activeReview + 1));
    dots?.addEventListener("click", (event) => {
      const dot = event.target instanceof Element ? event.target.closest("[data-review-dot]") : null;
      if (dot instanceof HTMLElement) showReview(Number(dot.dataset.reviewDot));
    });
  }
</script>
