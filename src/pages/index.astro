---
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Taller de Digitalización | Soluciones técnicas para negocios";
const description = "Taller de Digitalización reúne servicios técnicos para resolver problemas concretos de negocio: caos operativo y velocidad web.";

const products = [
  {
    eyebrow: "Operaciones",
    title: "Diagnóstico de Caos Operativo",
    text: "Para PyMEs que funcionan, pero con demasiada dependencia del dueño, fricción interna y procesos poco claros.",
    href: "/diagnostico-caos-operativo",
    cta: "Ver diagnóstico operativo",
  },
  {
    eyebrow: "Velocidad web",
    title: "Optimización de velocidad web",
    text: "Para webs lentas que pierden visitas, posicionamiento y contactos antes de que el cliente vea la oferta.",
    href: "/optimizacion-velocidad-web",
    cta: "Ver optimización de velocidad",
  },
];
---

<BaseLayout title={title} description={description} canonicalPath="/" showHeaderBooking={false} headerNavItems={[["Productos", "#productos"]]}>
  <section class="hero home-hero">
    <div class="hero-content">
      <span class="eyebrow">Taller de Digitalización</span>
      <h1>Soluciones técnicas para problemas concretos de negocio.</h1>
      <p class="hero-subtitle">Elige el problema que quieres resolver. Cada servicio tiene su propia página, su propio contexto y un único objetivo.</p>
    </div>
  </section>

  <section id="productos" class="section">
    <div class="section-head">
      <span class="eyebrow">Servicios</span>
      <h2>Dos dolores, dos caminos.</h2>
      <p>Esta página solo ordena la entrada. Las páginas de producto funcionan como funnels independientes, sin distracciones ni navegación cruzada.</p>
    </div>
    <div class="product-grid">
      {products.map((product) => (
        <article class="product-card">
          <span class="eyebrow">{product.eyebrow}</span>
          <h3>{product.title}</h3>
          <p>{product.text}</p>
          <a class="btn btn-primary" href={product.href}>{product.cta}</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
