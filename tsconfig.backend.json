{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "types": ["node", "aws-lambda"],
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["backend/**/*.ts", "infra/**/*.ts"]
}
